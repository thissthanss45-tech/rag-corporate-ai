GROQ_API_KEY=your_groq_key
DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_MODEL_NAME=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_REQUEST_TIMEOUT_SEC=70
DEEPSEEK_MAX_RETRIES=1
DEEPSEEK_RETRY_BACKOFF_SEC=1.5
DEEPSEEK_FALLBACK_TO_LLAMA=true
LLAMA_FALLBACK_TO_DEEPSEEK=true
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
OWNER_ID=123456789
SERVICE_AUTH_TOKEN=change-me-in-prod

MODEL_NAME=llama-3.3-70b-versatile
GROQ_REQUEST_TIMEOUT_SEC=35
GROQ_MAX_RETRIES=0
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

DATA_PATH=data
INDICES_PATH=indices
MAX_UPLOAD_SIZE_MB=20
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
TOP_K=7
INCLUDE_SOURCES_IN_ANSWER=true
MAX_SOURCES_IN_ANSWER=3
EVAL_DATASET_PATH=evaluation/dataset.jsonl
EVAL_MIN_RECALL_AT_K=0.60
EVAL_FAIL_ON_MISSING_DATASET=false
MAX_CONTEXT_CHARS_PER_CHUNK=1200
CONTEXT_CHUNKS_FOR_PROMPT=6
CONTEXT_INJECTION_GUARD=true
RETENTION_DAYS=90
ADMIN_IDS=

LOG_LEVEL=INFO
LOG_JSON=true
APP_ENV=production
SERVICE_AUTH_TOKEN=change-me-in-prod
MAX_AUDIO_SIZE_MB=25
MIN_FREE_DISK_MB=256
RATE_LIMIT_PER_MINUTE=180
ASK_MAX_RETRIES=2
ASK_RETRY_BACKOFF_SEC=0.8
ASK_MIN_RETRIEVAL_CHUNKS=12
ASK_CONTEXT_MAX_CHUNKS=9
ASK_CONTEXT_MAX_CHARS=14000
ASK_MIN_CONTEXT_COVERAGE=0.15
ASK_ENABLE_ANSWER_VERIFICATION=true
ASK_OUTPUT_MODE=standard
ASK_STRICT_GROUNDED_MODE=true
ASK_STRICT_MIN_SENTENCE_SUPPORT=0.6
ASK_STRICT_MIN_CONTEXT_CHARS=500
ASK_MAX_CONCURRENT_GENERATIONS=8
ASK_QUEUE_TIMEOUT_SEC=8.0
ASK_FALLBACK_ANSWER="Сервис сейчас перегружен. Я не успел подготовить точный ответ. Повтори запрос через 20–40 секунд или сократи вопрос."
UVICORN_WORKERS=2
WORKER_CONCURRENCY=4
API_TIMEOUT_SECONDS=90

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

METRICS_ENABLED=true
METRICS_PORT=9108
HEARTBEAT_FILE=/tmp/rag_bot_heartbeat
HEARTBEAT_INTERVAL_SEC=15
